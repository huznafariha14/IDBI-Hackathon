{
  "version": 2,
  "functions": {
    "backend/server.js": {
      "runtime": "nodejs20.x"
    }
  },
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "/backend/server.js"
    },
    {
      "source": "/health",
      "destination": "/backend/server.js"
    },
    {
      "source": "/:path*",
      "destination": "/frontend/dist/:path*"
    }
  ]
}
